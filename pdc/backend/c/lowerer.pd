utilizar bepd/builtins
utilizar bepd/x/puerto (PuertoDeEscritura)
utilizar bepd/utilidades/texto/ascii (LF)
utilizar bepd/utilidades/texto (Unir)
utilizar bepd/utilidades/iteración como Iter

utilizar pdc/backend/c/ir (Opcode, FunciónIR, Argumento, Retorno, Parámetro, TipoConstante, Constante, ContinuaciónIR, ProgramaIR, Etiqueta, EscribirPrograma)


[DOCUMENTA
@brief{Compila un programa (IR) y lo guarda en un puerto de escritura.}

@params(
@defparam("puertoDeEscritura"){@pd{PuertoDeEscritura} en el cual se escribirá
el código compilado.}

@defparam("identificadorDelMódulo"){Prefijo de compilación del módulo. Un
@pd{Texto}.}

@defparam("identificadoresDeDependencias"){@pd{Arreglo} de @pd{Texto}s con los
prefijos de compilación de todas las dependencias (incluyendo dependencias
transitivas) de este módulo.}

@defparam("programa"){El @pd{ProgramaIR} a compilar.}
)

@devuelve{Nada.}
DOCUMENTA]
procedimiento CompilarPrograma: puertoDeEscritura, identificadorDelMódulo, identificadoresDeDependencias, programa
    EmitirLínea: puertoDeEscritura, {#define PDCRT_INTERNO}
    EmitirLínea: puertoDeEscritura, {#include "pdcrt/pdcrt.h"}
    EmitirLínea: puertoDeEscritura, {#include "pdcrt/pdcrt_ops.h"}

    ParaCadaElemento: programa#funciones, procedimiento: func
        DeclararFunción: puertoDeEscritura, identificadorDelMódulo, func
    finprocedimiento
    ParaCadaElemento: programa#continuaciones, procedimiento: k
        DeclararContinuación: puertoDeEscritura, identificadorDelMódulo, k
    finprocedimiento

    ParaCadaElemento: programa#funciones, procedimiento: func
        CompilarFunción: puertoDeEscritura, identificadorDelMódulo, func, programa#metadata
    finprocedimiento
    ParaCadaElemento: programa#continuaciones, procedimiento: k
        CompilarContinuación: puertoDeEscritura, identificadorDelMódulo, k, programa#metadata
    finprocedimiento

    EmitirLínea: puertoDeEscritura, {PDCRT_DECLARAR_ENTRYPOINT(}, identificadorDelMódulo, {, }, (NombreDeLaFunción: identificadorDelMódulo, programa#idDeLaFunciónPrincipal), {)}

    EmitirLínea: puertoDeEscritura, {#ifdef PDCRT_MAIN}
    EmitirLínea: puertoDeEscritura, {#define PDCRT_DEPS(X) \}
    EmitirLínea: puertoDeEscritura, {    X(}, identificadorDelMódulo, {, }, (EscaparTexto: identificadorDelMódulo), {, }, identificadorDelMódulo#longitud, {)},
        ((identificadoresDeDependencias#longitud = 0)#escoger: {}, { \})
    ParaCadaElementoConÍndice: identificadoresDeDependencias, procedimiento: id, i
        EmitirLínea: puertoDeEscritura, {    X(}, id, {, }, (EscaparTexto: id), {, }, id#longitud, {)},
                     ((i < (identificadoresDeDependencias#longitud - 1))#escoger: { \}, {})
    finprocedimiento
    EmitirLínea: puertoDeEscritura, {PDCRT_DECLARAR_DEPS(PDCRT_DEPS)}
    EmitirLínea: puertoDeEscritura, {PDCRT_DECLARAR_MAIN(}, identificadorDelMódulo, {)}
    EmitirLínea: puertoDeEscritura, {#endif}
finprocedimiento

procedimiento Emitir: puerto, ...valores
    ParaCadaElemento: valores, procedimiento: valor
        puerto#escribirTexto: valor#comoTexto
    finprocedimiento
finprocedimiento

procedimiento EmitirLínea: puerto, ...valores
    Emitir: puerto, ...valores
    puerto#escribirTexto: {~%}#formatear
finprocedimiento

funcion NombreDeLaFunción: identificadorDelMódulo, id
    devolver {pdc_m~t_f~t}#formatear: identificadorDelMódulo, id
finfuncion

funcion NombreDeLaContinuación: identificadorDelMódulo, id
    devolver {pdc_m~t_k~t}#formatear: identificadorDelMódulo, id
finfuncion

funcion EscaparTexto: txt
    variable res
    fijar res a {}
    ParaCadaNúmero: 0, txt#longitud, procedimiento: i
        variable c
        fijar c a txt#en: i
        si c = {\}
            fijar res a res#concatenar: {\\}
            fijar c a {}
        finsi
        si c = {"}
            fijar res a res#concatenar: {\"}
            fijar c a {}
        finsi
        si c = {'}
            fijar res a res#concatenar: {\'}
            fijar c a {}
        finsi
        si c = LF
            fijar res a res#concatenar: {\n}
            fijar c a {}
        finsi
        si no c = {}
            fijar res a res#concatenar: c
        finsi
    finprocedimiento
    devolver ({"}#concatenar: res)#concatenar: {"}
finfuncion

procedimiento DeclararFunción: puerto, identificadorDelMódulo, func
    EmitirLínea: puerto, {static pdcrt_tk }, (NombreDeLaFunción: identificadorDelMódulo, func#id), {(pdcrt_ctx* ctx, int args, pdcrt_k k, PDCRT_F_IMM);}
finprocedimiento

procedimiento DeclararContinuación: puerto, identificadorDelMódulo, k
    EmitirLínea: puerto, {static pdcrt_tk }, (NombreDeLaContinuación: identificadorDelMódulo, k#id), {(pdcrt_ctx* ctx, pdcrt_marco* m, __m128i res);}
finprocedimiento

funcion NombreDeLaEstructuraConParámetros: identificadorDelMódulo, id
    devolver {pdc_params_data_m~t_p~t}#formatear: identificadorDelMódulo, id
finfuncion

procedimiento CompilarFunción: puerto, identificadorDelMódulo, func, metadataGlobal
    variable áreaTextual
    fijar áreaTextual a metadataGlobal#en: func#idcMetadata

    EmitirLínea: puerto, {static pdcrt_tk }, (NombreDeLaFunción: identificadorDelMódulo, func#id), {(pdcrt_ctx* ctx, int args, pdcrt_k k, PDCRT_F_IMM)}
    EmitirLínea: puerto, «{»
    EmitirLínea: puerto, ({/* ##SRCLOC## ~t => ~t:~t >> ~t:~t */}#formatear:
            (EscaparTexto: áreaTextual#posiciónInicial#nombreDelArchivo),
            áreaTextual#posiciónInicial#línea,
            áreaTextual#posiciónInicial#columna,
            áreaTextual#posiciónFinal#línea,
            áreaTextual#posiciónFinal#columna)
    EmitirLínea: puerto,
                 {static const char *const func_srcloc = },
                 (EscaparTexto:
                         ({~t|~t:~t|~t:~t}#formatear: áreaTextual#posiciónInicial#nombreDelArchivo,
                                                      áreaTextual#posiciónInicial#línea,
                                                      áreaTextual#posiciónInicial#columna,
                                                      áreaTextual#posiciónFinal#línea,
                                                      áreaTextual#posiciónFinal#columna)),
                 {;}

    [ FIXME: Como no hay un `VERIFICA_PILA` aquí, podríamos causar un stack-overflow ]
    EmitirLínea: puerto, {PDCRT_ALOJAR_MARCO(ctx, }, func#númRegistros, {, args, k, func_srcloc);}
    variables fid, idcVariadic, numRaíces
    fijar fid a NombreDeLaEstructuraConParámetros: identificadorDelMódulo, func#id
    EmitirLínea: puerto, «struct », fid, « { const pdcrt_params_base base; const pdcrt_param_data params[», (Max: 1, func#parámetros#longitud), «]; };»
    fijar idcVariadic a BuscarPredicado: 0, func#parámetros, (MétodoComoFunción: {esVariadic})
    EmitirLínea: puerto,
                 «static const struct », fid,
                 « pdc_params = { .base = { .num_params = », func#parámetros#longitud,
                 «, .tiene_variadic = », ((no EsNulo: idcVariadic)#escoger: {true}, {false}),
                 «, .idc_variadic = », ((EsNulo: idcVariadic)#escoger: 0, idcVariadic),
                 «, }, .params = {», (Unir: (Mapear: func#parámetros, funcion: p devolver «{~t}»#formatear: p#registro finfuncion), {, }),
                 «} };»
    EmitirLínea: puerto, {pdcrt_params(ctx, m, (pdcrt_params_data*) &pdc_params, PDCRT_A_IMM);}
    fijar numRaíces a Iter#Máximo: (Mapear: func#instrucciones, funcion: tupla
        devolver (tupla#en: 0)#numRaíces
    finfuncion)
    si numRaíces > 0
        EmitirLínea: puerto, {PDCRT_DEFINE_RAICES(}, numRaíces, {);}
    finsi
    ParaCadaElemento: func#instrucciones, procedimiento: tupla
        CompilarTupla: puerto, identificadorDelMódulo, tupla, metadataGlobal
    finprocedimiento
    EmitirLínea: puerto, «}»
finprocedimiento

procedimiento CompilarContinuación: puerto, identificadorDelMódulo, k, metadataGlobal
    variables nombre, numRaíces
    fijar nombre a NombreDeLaContinuación: identificadorDelMódulo, k#id
    EmitirLínea: puerto, {static pdcrt_tk }, nombre, {(pdcrt_ctx* ctx, pdcrt_marco* m, __m128i res)}
    EmitirLínea: puerto, «{»
    EmitirLínea: puerto, {PDCRT_VERIFICA_PILA(ctx, m, res, }, nombre, {);}
    fijar numRaíces a Iter#Máximo: (Mapear: k#instrucciones, funcion: tupla
        devolver (tupla#en: 0)#numRaíces
    finfuncion)
    si numRaíces > 0
        EmitirLínea: puerto, {PDCRT_DEFINE_RAICES(}, numRaíces, {);}
    finsi
    ParaCadaElemento: k#instrucciones, procedimiento: tupla
        CompilarTupla: puerto, identificadorDelMódulo, tupla, metadataGlobal
    finprocedimiento
    EmitirLínea: puerto, «}»
finprocedimiento

procedimiento CompilarTupla: puerto, identificadorDelMódulo, tupla, metadataGlobal
    variable áreaTextual
    fijar áreaTextual a metadataGlobal#en: (ÚltimoElemento: tupla)
    EmitirLínea: puerto, ({/* ##SRCLOC## ~t => ~t:~t >> ~t:~t */}#formatear:
            (EscaparTexto: áreaTextual#posiciónInicial#nombreDelArchivo),
            áreaTextual#posiciónInicial#línea,
            áreaTextual#posiciónInicial#columna,
            áreaTextual#posiciónFinal#línea,
            áreaTextual#posiciónFinal#columna)

    variable opcode
    fijar opcode a tupla#en: 0

    si opcode = Opcode#csaltar
        EmitirLínea: puerto, {pdcrt_obj csaltar_obj = pdcrt_obtener_local(ctx, m, }, (tupla#en: 2), {);}
        EmitirLínea: puerto, {if(csaltar_obj.recv != &pdcrt_recv_booleano) pdcrt_error(ctx, "Se esperaba un objeto de tipo Boole");}
        EmitirLínea: puerto, {if(csaltar_obj.bval)}
        EmitirLínea: puerto, {return pdcrt_saltar(ctx, m, }, (NombreDeLaContinuación: identificadorDelMódulo, (tupla#en: 1)#id), {, PDCRT_XMM_NULO());}
        EmitirLínea: puerto, {else}
        EmitirLínea: puerto, {return pdcrt_saltar(ctx, m, }, (NombreDeLaContinuación: identificadorDelMódulo, (tupla#en: 3)), {, PDCRT_XMM_NULO());}
    finsi

    si opcode = Opcode#saltar
        EmitirLínea: puerto, {return pdcrt_saltar(ctx, m, }, (NombreDeLaContinuación: identificadorDelMódulo, (tupla#en: 1)#id), {, PDCRT_XMM_NULO());}
    finsi

    si opcode = Opcode#continuar
        EmitirLínea: puerto, {return pdcrt_saltar(ctx, m, }, (NombreDeLaContinuación: identificadorDelMódulo, (tupla#en: 1)), {, PDCRT_XMM_NULO());}
    finsi

    si (opcode = Opcode#enviarMensaje_s1) || (opcode = Opcode#enviarMensaje_t)
        variables rets, args, msj, objReg, tieneArgsVariadic, k, tailCall
        fijar rets a tupla#en: 1
        fijar objReg a tupla#en: 2
        fijar msj a tupla#en: 3
        fijar args a tupla#en: 4
        fijar tailCall a opcode = Opcode#enviarMensaje_t
        si no tailCall
            fijar k a NombreDeLaContinuación: identificadorDelMódulo, (tupla#en: 5)
        finsi
        necesitas rets#longitud = 1
        necesitas no (rets#en: 0)#esVariadic

        fijar tieneArgsVariadic a Algún: (Mapear: args, (MétodoComoFunción: {esVariadic}))
        si tieneArgsVariadic
            EmitirLínea: puerto, {static const int proto[] =}
            Emitir: puerto, «{ »
            ParaCadaElemento: args, procedimiento: arg
                Emitir: puerto, (arg#esVariadic#escoger: {1}, {0}), {, }
            finprocedimiento
            EmitirLínea: puerto, «};»
            EmitirLínea: puerto, {pdcrt_extender_pila(ctx, }, args#longitud, {);}
            ParaCadaElemento: args, procedimiento: arg
                EmitirLínea: puerto, {pdcrt_empujar(ctx, pdcrt_obtener_local(ctx, m, }, arg#registro, {));}
            finprocedimiento

            EmitirLínea: puerto, {size_t llamar_nargs = pdcrt_expandir_varargs(ctx, proto, }, args#longitud, {);}
            EmitirLínea: puerto, {pdcrt_obj llamar_msj = PDCRT_OBTENER_CONSTANTE(ctx, m, }, msj, {);}
            si tailCall
                EmitirLínea: puerto,
                             {return pdcrt_llamarn(ctx, m->k.marco, m->k.kf, llamar_nargs, pdcrt_xmm_desde_obj(pdcrt_obtener_local(ctx, m, },
                             objReg,
                             {)), pdcrt_xmm_desde_obj(llamar_msj));}
            sino
                EmitirLínea: puerto,
                             {return pdcrt_llamarn(ctx, m, },
                             k,
                             {, llamar_nargs, pdcrt_xmm_desde_obj(pdcrt_obtener_local(ctx, m, },
                             objReg,
                             {)), pdcrt_xmm_desde_obj(llamar_msj));}
            finsi
        sino
            variables extraArgs, sufijoLlamar, argsEnLaPila, llamarNargs
            si args#longitud =< 6
                fijar sufijoLlamar a args#longitud#comoTexto
                fijar llamarNargs a {}
            sino
                fijar sufijoLlamar a {nr}
                fijar llamarNargs a {, }#concatenar: args#longitud#comoTexto
            finsi

            fijar extraArgs a {}
            ParaCadaNúmero: 0, (Min: 6, args#longitud), procedimiento: i
                variable arg
                fijar arg a args#en: i
                fijar extraArgs a extraArgs#concatenar: ({, pdcrt_xmm_desde_obj(pdcrt_obtener_local(ctx, m, ~t))}#formatear: arg#registro)
            finprocedimiento

            fijar argsEnLaPila a Max: 0, (args#longitud - 6)
            si argsEnLaPila > 0
                EmitirLínea: puerto, {pdcrt_extender_pila(ctx, }, argsEnLaPila, {);}
                ParaCadaNúmero: 6, args#longitud, procedimiento: i
                    variable arg
                    fijar arg a args#en: i
                    EmitirLínea: puerto, {pdcrt_empujar(ctx, pdcrt_obtener_local(ctx, m, }, arg#registro, {));}
                finprocedimiento
            finsi

            EmitirLínea: puerto, {pdcrt_obj llamar_msj = PDCRT_OBTENER_CONSTANTE(ctx, m, }, msj, {);}
            si tailCall
                EmitirLínea: puerto,
                             {return pdcrt_llamar}, sufijoLlamar, {(ctx, m->k.marco, m->k.kf},
                             llamarNargs,
                             {, pdcrt_xmm_desde_obj(pdcrt_obtener_local(ctx, m, },
                             objReg,
                             {)), pdcrt_xmm_desde_obj(llamar_msj)}, extraArgs, {);}
            sino
                EmitirLínea: puerto,
                             {return pdcrt_llamar}, sufijoLlamar, {(ctx, m, },
                             k,
                             llamarNargs,
                             {, pdcrt_xmm_desde_obj(pdcrt_obtener_local(ctx, m, },
                             objReg,
                             {)), pdcrt_xmm_desde_obj(llamar_msj)}, extraArgs, {);}
            finsi
        finsi
    finsi

    si opcode = Opcode#enviarMensaje_s2
        variables rets, args, msj, objReg
        fijar rets a tupla#en: 1
        fijar objReg a tupla#en: 2
        fijar msj a tupla#en: 3
        fijar args a tupla#en: 4
        necesitas rets#longitud = 1
        necesitas no (rets#en: 0)#esVariadic
        EmitirLínea: puerto, {pdcrt_fijar_local(ctx, m, }, (rets#en: 0)#registro, {, pdcrt_obj_desde_xmm(res));}
    finsi

    si opcode = Opcode#fijarRegistro
        EmitirLínea: puerto, {pdcrt_fijar_local_nb(ctx, m, }, (tupla#en: 1), {, pdcrt_obtener_local(ctx, m, }, (tupla#en: 2), {));}
    finsi

    si opcode = Opcode#caja
        EmitirLínea: puerto, «do {»
        EmitirLínea: puerto, {PDCRT_REINICIAR_RAICES();}
        EmitirLínea: puerto, {PDCRT_GUARDAR_RAIZ_CABECERA(0, m);}
        EmitirLínea: puerto, {pdcrt_obj caja = pdcrt_objeto_caja(pdcrt_crear_caja(ctx, PDCRT_GC()));}
        EmitirLínea: puerto, {PDCRT_CARGAR_RAIZ_CABECERA(0, m);}
        EmitirLínea: puerto, {pdcrt_fijar_caja(ctx, caja, pdcrt_obtener_local(ctx, m, }, (tupla#en: 2), {));}
        EmitirLínea: puerto, {pdcrt_fijar_local(ctx, m, }, (tupla#en: 1), {, caja);}
        EmitirLínea: puerto, «} while(0);»
    finsi

    si opcode = Opcode#fijarCaja
        EmitirLínea: puerto, {pdcrt_fijar_caja(ctx, pdcrt_obtener_local(ctx, m, }, (tupla#en: 1), {), pdcrt_obtener_local(ctx, m, }, (tupla#en: 2), {));}
    finsi

    si opcode = Opcode#valorDeCaja
        EmitirLínea: puerto,
                     {pdcrt_fijar_local(ctx, m, }, (tupla#en: 1),
                     {, pdcrt_obtener_caja(ctx, pdcrt_obtener_local(ctx, m, }, (tupla#en: 2), {)));}
    finsi

    si opcode = Opcode#prn
        EmitirLínea: puerto, «do {»
        EmitirLínea: puerto, {pdcrt_obj v = pdcrt_obtener_local(ctx, m, }, (tupla#en: 1), {);}
        EmitirLínea: puerto, {pdcrt_debe_tener_tipo(ctx, v, PDCRT_TOBJ_TEXTO);}
        EmitirLínea: puerto, {printf("%.*s", (int) v.texto->longitud, v.texto->contenido);}
        EmitirLínea: puerto, «} while(0);»
    finsi

    si opcode = Opcode#prnl
        EmitirLínea: puerto, {putchar('\n');}
    finsi

    si opcode = Opcode#assert
        EmitirLínea: puerto, {pdcrt_assert(ctx, pdcrt_obtener_local(ctx, m, }, (tupla#en: 1), {));}
    finsi

    si opcode = Opcode#devolverN
        variable rets
        fijar rets a tupla#en: 1
        necesitas rets#longitud = 1
        necesitas no (rets#en: 0)#esVariadic
        EmitirLínea: puerto, {return pdcrt_devolver1(ctx, m, pdcrt_xmm_desde_obj(pdcrt_obtener_local(ctx, m, }, (rets#en: 0)#registro, {)));}
    finsi

    si opcode = Opcode#número
        variable n
        fijar n a tupla#en: 2
        si n#techo = n
            EmitirLínea: puerto, {pdcrt_fijar_local_nb(ctx, m, }, (tupla#en: 1), {, pdcrt_objeto_entero(PDCRT_ENTERO_C(}, n, {)));}
        sino
            EmitirLínea: puerto, {pdcrt_fijar_local_nb(ctx, m, }, (tupla#en: 1), {, pdcrt_objeto_float(PDCRT_FLOAT_C(}, n, {)));}
        finsi
    finsi

    si opcode = Opcode#crearConstantes
        EmitirLínea: puerto, «do {»
        EmitirLínea: puerto, {PDCRT_REINICIAR_RAICES();}
        EmitirLínea: puerto, {PDCRT_GUARDAR_RAIZ_CABECERA(0, m);}
        EmitirLínea: puerto, {pdcrt_arreglo *constantes = pdcrt_crear_arreglo_vacio(ctx, PDCRT_GC(), }, (tupla#en: 1)#longitud, {LLU);}
        EmitirLínea: puerto, {PDCRT_CARGAR_RAIZ_CABECERA(0, m);}

        ParaCadaElemento: (tupla#en: 1), procedimiento: const
            necesitas const#tipo = TipoConstante#TEXTO
            EmitirLínea: puerto, «do {»
            EmitirLínea: puerto, {PDCRT_REINICIAR_RAICES();}
            EmitirLínea: puerto, {PDCRT_GUARDAR_RAIZ_CABECERA(0, m);}
            EmitirLínea: puerto, {PDCRT_GUARDAR_RAIZ_CABECERA(1, constantes);}
            EmitirLínea: puerto,
                         {pdcrt_obj txt = pdcrt_objeto_texto(pdcrt_crear_texto(ctx, PDCRT_GC(), }, (EscaparTexto: const#valor),
                         {, }, const#valor#longitud, {));}
            EmitirLínea: puerto, {PDCRT_CARGAR_RAIZ_CABECERA(0, m);}
            EmitirLínea: puerto, {PDCRT_CARGAR_RAIZ_CABECERA(1, constantes);}

            EmitirLínea: puerto, {pdcrt_barrera_de_escritura(ctx, pdcrt_objeto_arreglo(constantes), txt);}
            EmitirLínea: puerto, {constantes->valores[constantes->longitud++] = txt;}
            EmitirLínea: puerto, «} while(0);»
        finprocedimiento

        EmitirLínea: puerto, {PDCRT_FIJAR_CONSTANTES(ctx, m, constantes);}
        EmitirLínea: puerto, «} while(0);»
    finsi

    si opcode = Opcode#texto
        EmitirLínea: puerto, {pdcrt_fijar_local(ctx, m, }, (tupla#en: 1), {, PDCRT_OBTENER_CONSTANTE(ctx, m, }, (tupla#en: 2), {));}
    finsi

    si opcode = Opcode#nulo
        EmitirLínea: puerto, {pdcrt_fijar_local_nb(ctx, m, }, (tupla#en: 1), {, pdcrt_objeto_nulo());}
    finsi

    si opcode = Opcode#negar
        EmitirLínea: puerto, «do {»
        EmitirLínea: puerto, {pdcrt_obj b = pdcrt_obtener_local(ctx, m, }, (tupla#en: 2), {);}
        EmitirLínea: puerto, {if(pdcrt_tipo_de_obj(b) != PDCRT_TOBJ_BOOLEANO) pdcrt_error(ctx, "Se esperaba un objeto booleano");}
        EmitirLínea: puerto, {pdcrt_fijar_local_nb(ctx, m, }, (tupla#en: 1), {, pdcrt_objeto_booleano(!b.bval));}
        EmitirLínea: puerto, «} while(0);»
    finsi

    si opcode = Opcode#sonIdénticos
        EmitirLínea: puerto,
                     {pdcrt_fijar_local_nb(ctx, m, }, (tupla#en: 1),
                     {, pdcrt_objeto_booleano(pdcrt_son_identicos(ctx, m, pdcrt_obtener_local(ctx, m, }, (tupla#en: 2),
                     {), pdcrt_obtener_local(ctx, m, }, (tupla#en: 3), {))));}
    finsi

    si opcode = Opcode#obtenerObjeto
        EmitirLínea: puerto, {pdcrt_fijar_local(ctx, m, }, (tupla#en: 1), {, ctx->clase_objeto);}
