                           {VEL_NORMAL}, {VEL_AGRESIVA}, {VEL_MUY_AGRESIVA},
                           {TAM_NORMAL}, {TAM_AGRESIVA},
                           {DEPURACIÓN}

variable OpcionesAdicionales
fijar OpcionesAdicionales a TipoDeDatos: {OpcionesAdicionales},
    {cc},
    {ld},
    {cpp},
    {asm}

variable TipoDepuración
fijar TipoDepuración a Enum: {TipoDepuración}, {NINGUNA}, {NORMAL}, {GDB}

variable SalidaInterfáz
fijar SalidaInterfáz a TipoDeDatos: {SalidaInterfáz},
    {paquete}, {módulo}, {rutaAlArchivo}

variable Salidas
