    (Alternativa: {archivo}, {lenguaje}, {rutaAlArchivo}, {identificadorDelMódulo}),
    (Alternativa: {módulo}, {lenguaje}, {paquete}, {módulo}, {rutaAlArchivo}, {identificadorDelMódulo})

variable Lenguaje
fijar Lenguaje a EnumConValores: {Lenguaje},
