                                 {CABECERA_C}, {c-header},
                                 {C_PREPROCESADO}, {cpp-output},
                                 {ENSAMBLADOR}, {assembler},
                                 {ENSAMBLADOR_CON_PREPROCESADOR}, {assembler-with-cpp},
                                 {PSEUDOD}, {pseudod},
                                 {INTERFAZ_PSEUDOD}, {pd-ipd},
                                 {OBJETO_PSEUDOD}, {pd-opd},
                                 {BIBLIOTECA_PSEUDOD}, {pd-bpd},
                                 {OBJETO_PARA_EL_ENLAZADOR}, {ld}

