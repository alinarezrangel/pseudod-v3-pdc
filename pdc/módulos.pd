utilizar bepd/builtins
utilizar bepd/x/sistemaDeArchivos/archivo (LeerArchivo)
utilizar bepd/x/datos (TipoDeDatos)
utilizar bepd/x/puerto/deArchivo (PuertoDeArchivoDeLectura, PuertoDeArchivoDeEscritura)
utilizar bepd/x/json (DesdeJSON, ComoJSON)

utilizar pdc/tabla (CrearTipoDeRegistro, Tabla, Índice, EscribirTabla)


[DOCUMENTA
@brief{Un valor exportado desde un módulo.}

@itemlist(
@item{@code{nombre}: Nombre de la exportación.}

@item{@code{esAutoejecutable}: Si es autoejecutable o no.}
)
DOCUMENTA]
variable Exportación
fijar Exportación a TipoDeDatos: {Exportación}, {nombre}, {esAutoejecutable}

[DOCUMENTA
@brief{Módulo de PseudoD.}

@itemlist(
@item{@code{id}: ID del módulo. Solo es usado internamente por el compilador y
no es guardado en los archivos de interfáz de módulo.}

@item{@code{paquete}: Nombre del paquete.}

@item{@code{módulo}: Nombre del módulo.}

@item{@code{exportaciones}: Arreglo de @pd{Exportación} con las exportaciones
del módulo.}

@item{@code{prefijoDelMódulo}: Prefijo del módulo para el linker.}

@item{@code{compilado}: Objeto con todos los datos resultantes de la
compilación. Su tipo específico depende del backend que compiló el módulo.}

@item{@code{prefijosDeLosMódulosTransitivos}: Arreglo con los prefijos de todos
los módulos que son dependencias de este. Es utilizado por el lowerer para
precargar los módulos del programa.}
)
DOCUMENTA]
variable Módulo
fijar Módulo a CrearTipoDeRegistro: {Módulo},
    {id}, {paquete}, {módulo}, {exportaciones},
    {prefijoDelMódulo}, {compilado},
    {prefijosDeLosMódulosTransitivos},
    (Índice#ÚNICO: {id}),
    (Índice#ORDENADO: {paquete}),
    (Índice#ORDENADO: {paquete}, {módulo})


[DOCUMENTA
@brief{Base de datos de módulos.}

Contiene la tabla de @pd{Módulo}s. Almacena, busca y guarda la base de datos.
DOCUMENTA]
clase BaseDeDatosDeMódulos
    [DOCUMENTA
    @brief{Crea una base de datos vacía.}
    DOCUMENTA]
    metodo estatico enMemoria

    [DOCUMENTA
    @brief{Obtiene la tabla de @pd{Módulo}s.}
    DOCUMENTA]
    metodo tablaMódulos

    [DOCUMENTA
    @brief{Carga una interfaz PseudoD desde un archivo, agregando su módulo a
    la base de datos.}
    DOCUMENTA]
    metodo cargarDesdeArchivo: paquete, módulo, archivo

    [DOCUMENTA
    @brief{Guarda el módulo seleccionado en un archivo.}
    DOCUMENTA]
    metodo guardarEnArchivo: paquete, módulo, archivo

    [DOCUMENTA
    @brief{Carga la biblioteca PseudoD desde el archivo dado.}

    Todos los módulos son instalados como parte del paquete especificado.
    DOCUMENTA]
    metodo cargarBiblioteca: paquete, archivo

    [DOCUMENTA
    @brief{Guarda todos los módulos de un paquete en un archivo.}
    DOCUMENTA]
    metodo guardarBiblioteca: paquete, archivo

    [DOCUMENTA
    @brief{Agrega un nuevo módulo a la base de datos.}

    Construye un @pd{Módulo} con los argumentos dados.
    DOCUMENTA]
    metodo agregarMódulo: paquete, módulo, exportaciones, prefijoDelMódulo, compilado, prefijosDeLosMódulosTransitivos

    [DOCUMENTA
    @brief{Intenta buscar un módulo en base a su paquete y nombre.}

    Si el módulo dado no existe, devuelve @pd{NULO}.
    DOCUMENTA]
    metodo intentaBuscarMódulo: paquete, nombre

    [DOCUMENTA
    @brief{Busca un módulo desde su paquete y nombre.}

    Si el módulo no es encontrado, falla con un error.
    DOCUMENTA]
    metodo buscarMódulo: paquete, nombre
finclase

atributo BaseDeDatosDeMódulos#tablaMódulos, BaseDeDatosDeMódulos#_contadorId

metodo estatico BaseDeDatosDeMódulos#enMemoria
    devolver yo#crear: (Tabla#vacíaConEsquema: Módulo)
finmetodo

metodo BaseDeDatosDeMódulos#inicializar: tabla
    fijar yo#tablaMódulos a tabla
    fijar yo#_contadorId a 0
finmetodo

metodo BaseDeDatosDeMódulos#cargarDesdeArchivo: paquete, módulo, archivo
    variables puerto, json, v
    fijar puerto a PuertoDeArchivoDeLectura#desdeArchivo: archivo
    fijar json a DesdeJSON: puerto
    si json#esError
        __FallarConMensaje: json#error
    finsi
    fijar json a json#valor
    fijar v a json#en: {versión}
    si v = 1
        yo#_cargarDesdeArchivoV1: paquete, módulo, json
    sino
        __FallarConMensaje: ({No se pudo cargar la base de datos con la versión ~t}#formatear: v)
    finsi
finmetodo

metodo BaseDeDatosDeMódulos#_cargarDesdeArchivoV1: paquete, módulo, json
    variable exportaciones, prefijo, prefijos
    fijar exportaciones a Mapear: (json#en: {exportaciones}), funcion: exp
        devolver Exportación#crear: (exp#en: {nombre}), (exp#en: {esAutoejecutable})
    finfuncion
    fijar prefijo a json#en: {prefijoDelMódulo}
    fijar prefijos a json#en: {prefijosDeLosMódulosTransitivos}
    yo#agregarMódulo: paquete, módulo, exportaciones, prefijo, NULO, prefijos
finmetodo

metodo BaseDeDatosDeMódulos#guardarEnArchivo: paquete, módulo, archivo
    variables puerto, modJson, res, mod
    fijar mod a yo#buscarMódulo: paquete, módulo
    fijar puerto a PuertoDeArchivoDeEscritura#desdeArchivo: archivo
    fijar modJson a yo#_guardarComoArchivoV1: mod
    fijar res a ComoJSON: puerto, modJson
    si res#esError
        __FallarConMensaje: res#error
    finsi
finmetodo

metodo BaseDeDatosDeMódulos#_guardarComoArchivoV1: módulo
    variable modJson
    fijar modJson a Diccionario#desdePares: {versión}, 1
    modJson#fijarEn: {exportaciones}, (Mapear: módulo#exportaciones, funcion: exp
        devolver Diccionario#desdePares:
                {nombre}, exp#nombre,
                {esAutoejecutable}, exp#esAutoejecutable
    finfuncion)
    modJson#fijarEn: {prefijoDelMódulo}, módulo#prefijoDelMódulo
    modJson#fijarEn: {prefijosDeLosMódulosTransitivos}, módulo#prefijosDeLosMódulosTransitivos
    devolver modJson
finmetodo

metodo BaseDeDatosDeMódulos#cargarBiblioteca: paquete, archivo
    variables puerto, json, v
    fijar puerto a PuertoDeArchivoDeLectura#desdeArchivo: archivo
    fijar json a DesdeJSON: puerto
    si json#esError
        __FallarConMensaje: json#error
    finsi
    fijar json a json#valor
    fijar v a json#en: {versión}
    si v = 1
        devolver yo#_cargarBibliotecaV1: paquete, json
    sino
        __FallarConMensaje: ({No se pudo cargar la base de datos con la versión ~t}#formatear: v)
    finsi
finmetodo

metodo BaseDeDatosDeMódulos#_cargarBibliotecaV1: paquete, json
    variable nombres
    fijar nombres a Arreglo#vacio
    ParaCadaElemento: (json#en: {módulos}), procedimiento: ipd
        yo#_cargarDesdeArchivoV1: paquete, (ipd#en: {módulo}), ipd
        nombres#agregarAlFinal: (ipd#en: {módulo})
    finprocedimiento
    devolver nombres
finmetodo

metodo BaseDeDatosDeMódulos#guardarBiblioteca: paquete, archivo
    variables módulos, objJson, puerto, res
    fijar módulos a yo#tablaMódulos#buscarOrdenado: {paquete}, paquete
    fijar puerto a PuertoDeArchivoDeEscritura#desdeArchivo: archivo
    fijar objJson a yo#_guardarBibliotecaV1: módulos
    fijar res a ComoJSON: puerto, objJson
    si res#esError
        __FallarConMensaje: res#error
    finsi
finmetodo

metodo BaseDeDatosDeMódulos#_guardarBibliotecaV1: módulos
    variable ipds
    fijar ipds a Arreglo#vacio
    ParaCadaElemento: módulos, procedimiento: mod
        variable modJson
        fijar modJson a yo#_guardarComoArchivoV1: mod
        modJson#fijarEn: {módulo}, mod#módulo
        ipds#agregarAlFinal: modJson
    finprocedimiento
    devolver Diccionario#desdePares: {versión}, 1, {módulos}, ipds
finmetodo

metodo BaseDeDatosDeMódulos#agregarMódulo: paquete, módulo, exportaciones, prefijoDelMódulo, compilado, prefijosDeLosMódulosTransitivos
    variable módulos
    fijar módulos a yo#tablaMódulos#buscarOrdenado: {paquete}, paquete, {módulo}, módulo
    si módulos#longitud > 0
        __FallarConMensaje: ({No se puede registrar el módulo ~t::~t: ya existe}#formatear: paquete, módulo)
    finsi
    variable id
    fijar id a yo#_generarId
    yo#tablaMódulos#agregar:
        (Módulo#crear: id,
                       paquete,
                       módulo,
                       exportaciones,
                       prefijoDelMódulo,
                       compilado,
                       prefijosDeLosMódulosTransitivos)
    devolver id
finmetodo

metodo BaseDeDatosDeMódulos#_generarId
    fijar yo#_contadorId a yo#_contadorId + 1
    devolver yo#_contadorId
finmetodo

metodo BaseDeDatosDeMódulos#intentaBuscarMódulo: paquete, nombre
    variable módulos
    fijar módulos a yo#tablaMódulos#buscarOrdenado: {paquete}, paquete, {módulo}, nombre
    si módulos#longitud = 1
        devolver módulos#en: 0
    sino
        devolver NULO
    finsi
finmetodo

metodo BaseDeDatosDeMódulos#buscarMódulo: paquete, nombre
    variable mod
    fijar mod a yo#intentaBuscarMódulo: paquete, nombre
    si EsNulo: mod
        Escribir: (yo#tablaMódulos#buscarOrdenado: {paquete}, paquete, {módulo}, nombre)
        yo#tablaMódulos#escaneoLineal: procedimiento: mod
            Escribir: ({~t::~t}#formatear: mod#paquete, mod#módulo)
        finprocedimiento
        __FallarConMensaje: ({No se encontró el módulo ~t::~t}#formatear: paquete, nombre)
    finsi
    devolver mod
finmetodo
